# IMPORTANT: This is an example file. Copy to .secrets and fill in real values.
# .secrets file is gitignored and will NOT be committed to version control.

# JWT Secret (use: openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_here_use_openssl_rand_hex_32

# Invite Code (set your own secret invite code)
INVITE_CODE=your_invite_code_here

# These secrets will be passed to CloudFormation during deployment
# Usage: source .secrets && ./deploy.sh --stack-only

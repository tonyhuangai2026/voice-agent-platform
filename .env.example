# ========================================
# Voice Agent Platform - Environment Variables
# ========================================

# --- Chime Voice Connector (required for voice-server) ---
CHIME_VOICE_CONNECTOR_HOST=xxxxx.voiceconnector.chime.aws
CHIME_PHONE_NUMBER=+1XXXXXXXXXX
PUBLIC_IP=                    # Elastic IP (auto-set in ECS via CloudFormation)
RTP_PORT_BASE=10000
RTP_PORT_COUNT=10000

# --- SIP (optional, for call transfer) ---
SIP_ENDPOINT=

# --- AWS configuration ---
AWS_REGION=us-east-1

# --- DynamoDB table names ---
CUSTOMERS_TABLE=outbound-customers
PROMPTS_TABLE=outbound-prompts
FLOWS_TABLE=outbound-flow-configs

# --- S3 / Connect storage (backend) ---
# TRANSCRIPT_BUCKET and TRANSCRIPT_PREFIX are auto-resolved from Connect API.
# Only set these to override the auto-detected values.
# TRANSCRIPT_BUCKET=
# TRANSCRIPT_PREFIX=
VOICE_ANALYSIS_PREFIX=Analysis/Voice/ivr/

# --- Amazon Connect (backend) ---
INSTANCE_ID=

# --- Voice Server ---
PORT=3000
VOICE_ID=tiffany
TEMPERATURE=0.7
TOP_P=0.9
MAX_TOKENS=1024
SYSTEM_PROMPT=
MAX_CALL_DURATION_MS=1200000
DYNAMODB_REGION=us-west-2

# --- Call Records / Monitoring ---
CALL_RECORDS_TABLE=outbound-call-records
ECS_CLUSTER_NAME=voice-agent-cluster
ECS_SERVICE_NAME=voice-agent-service

# --- Frontend ---
VITE_API_BASE=http://localhost:3001
VITE_VOICE_SERVER_BASE=http://localhost:3000
